{
  "expo": {
    "name": "PetParent",
    "slug": "petparent",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "petparent",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF8F0"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.aty.petparent",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "PetParent needs access to your photo library so you can add photos to your pet profiles.",
        "NSCameraUsageDescription": "PetParent needs access to your camera so you can take photos of your pets.",
        "NSPhotoLibraryAddUsageDescription": "PetParent needs permission to save photos to your library.",
        "NSUserTrackingUsageDescription": "PetParent uses this to personalize your experience and help us improve the app. Your data is never sold to third parties."
      }
    },
    "android": {
      "package": "com.petparent",
      "adaptiveIcon": {
        "backgroundColor": "#FAF8F0",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://petparent.app/"
        }
      ],
      [
        "expo-secure-store"
      ],
      "expo-font",
      "expo-web-browser",
      "expo-tracking-transparency",
      "expo-notifications",
      "expo-image-picker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
